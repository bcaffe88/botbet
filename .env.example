# ===============================================
# 🔑 VARIÁVEIS DE AMBIENTE - BOTBET
# ===============================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no Git!

# ===============================================
# 🤖 BOT PRINCIPAL (main.py)
# ===============================================

# Telegram Bot Token (via @BotFather)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram API (via my.telegram.org)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# IDs dos Canais (números negativos)
# Como obter: https://t.me/userinfobot
CHAT_ID_SINAL=-1001234567890    # Canal que envia sinais originais
CHAT_ID_DESTINO=-1009876543210  # Canal para sinais filtrados

# API Football (api-sports.io)
FOOTBALL_API_KEY=abcdef1234567890abcdef1234567890

# ===============================================
# 💳 SISTEMA DE ASSINATURAS (overbot_vip.py)
# ===============================================

# Bot Admin
BOT_TOKEN_ADMIN=987654321:ZYXwvuTSRqponMLKjihgFEDcba
CHANNEL_ID_ADMIN=-1001122334455  # Canal VIP para assinantes

# Configuração Admin
ADMIN_USER_ID=895248440           # ID do usuário admin
BOT_USERNAME_ADMIN=overbotvip_bot # Username do bot (sem @)

# Banco de Dados PostgreSQL
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/botbet

# Stripe (Pagamentos)
STRIPE_API_KEY=sk_live_abcdef1234567890
STRIPE_WEBHOOK_SECRET=whsec_abcdef1234567890

# Links de Checkout Stripe
STRIPE_LINK_MENSAL=https://buy.stripe.com/test_abc123
STRIPE_LINK_VITALICIO=https://buy.stripe.com/test_def456
STRIPE_LINK_OFERTA_VITALICIO=https://buy.stripe.com/test_ghi789

# ===============================================
# 🔧 OPCIONAIS (Já tem valores padrão)
# ===============================================

# Bônus/Penalidades Histórico
# HIST_BONUS_HIGH=0.65     # Bônus para histórico muito favorável
# HIST_BONUS_MED=0.50      # Bônus para histórico moderado
# HIST_PENALTY_RED=0.50    # Penalidade para último resultado RED

# Cache de Estatísticas
# ESTATISTICAS_DB_PATH=estatisticas.db
# ESTATISTICAS_CACHE_DIAS=7

# Servidor
# PORT=8080

# ===============================================
# ❌ INATIVAS (Implementadas mas não usadas)
# ===============================================

# OpenAI (para ativar a geração de explicações)
# OPENAI_API_KEY=sk-abcdef1234567890

# ===============================================
# 📝 NOTAS
# ===============================================
# 
# 1. TELEGRAM:
#    - Crie bots via @BotFather
#    - Obtenha API_ID/API_HASH em my.telegram.org
#    - Chat IDs são negativos para canais/grupos
#    - Use @userinfobot para descobrir IDs
#
# 2. API FOOTBALL:
#    - Crie conta em api-sports.io
#    - Plano gratuito: 100 requests/dia
#    - Plano básico: 2.000 requests/dia (recomendado)
#
# 3. STRIPE:
#    - Crie conta em stripe.com
#    - Use modo TEST primeiro
#    - Configure webhook em /stripe-webhook
#    - Ative apenas o evento: checkout.session.completed
#
# 4. POSTGRESQL:
#    - Railway.app: gratuito até 500MB
#    - Heroku: add-on Heroku Postgres
#    - Local: postgresql://postgres:senha@localhost:5432/botbet
#
# 5. SEGURANÇA:
#    - NUNCA commite este arquivo com valores reais
#    - Adicione .env ao .gitignore
#    - Use HTTPS em todos os webhooks
#    - Rotacione chaves periodicamente
#
# ===============================================
# 📚 DOCUMENTAÇÃO COMPLETA
# ===============================================
# Veja DOCUMENTATION.md para instruções detalhadas
# sobre como obter cada chave e configurar o sistema.
